---
import dayjs from "dayjs";
import E from "../E.astro";

const { title, date, updateDate, category, description, link } = Astro.props;
---

<h1 class="heading-1">
  <a href={link}>
    {title}
  </a>
</h1>

{
  date && (
    <>
      <span>posted on {dayjs(date).format("YYYY-MM-DD")}</span>
      <span class=":uno: bg-slate-600 px-2 mx-2 rounded text-gray-100">{category}</span>
    </>
  )
}

{
  description && (
    <p>
      <E>{description}</E>
    </p>
  )
}
