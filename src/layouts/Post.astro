---
import Shell from "./Shell.astro";

import TitleCard from "../components/Layout/TitleCard.astro";

const { title, date, updateDate, category, description } = Astro.props.frontmatter;
---

<Shell title={title} ogTitle={title} ogDescription={description}>
  <article class="prose prose-invert max-w-full">
    <TitleCard title={title} date={date} updateDate={updateDate} category={category} description="" />
    <slot />
  </article>
</Shell>
